{
  "name": "opencode-gh-actions-status",
  "version": "0.1.0",
  "description": "OpenCode plugin that surfaces GitHub Actions workflow run statuses in the sidebar",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  }
}
