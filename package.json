{
  "name": "opencode-gh-actions-status",
  "version": "0.2.0",
  "description": "OpenCode plugin that surfaces GitHub Actions workflow run statuses in the sidebar",
  "type": "module",
  "license": "MIT",
  "author": "Caleb Lenoir",
  "repository": {
    "type": "git",
    "url": "https://github.com/calebl/opencode-gh-actions-status.git"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "github-actions",
    "ci"
  ],
  "homepage": "https://github.com/calebl/opencode-gh-actions-status",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "bun tsc",
    "typecheck": "bun tsc --noEmit",
    "test": "bun vitest run",
    "test:watch": "bun vitest"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.1",
    "@emnapi/runtime": "^1.9.1",
    "@emnapi/wasi-threads": "^1.2.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/bun": "^1.3.11",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  }
}
